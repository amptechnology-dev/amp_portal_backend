<!doctype html>
<html lang="en">
  <%- include('../partials/head', { title: 'Edit User'}); %>
  <body>
    <script>
      var error = "<%= error %>";
      if (error) {
        alert(error);
      }
    </script>
    <div class="container">
      <div class="py-3">
        <a href="/admin/users" class="btn btn-primary">&lt; All Users</a>
      </div>
      <h3 class="my-4">Edit User Data</h3>
      <div class="row gap-3">
        <div class="card shadow mb-5 col-8">
          <div class="card-body">
            <form action="/admin/user/edit/<%= user._id %>" method="post">
              <div class="row mb-3">
                <div class="col">
                  <select class="form-select" name="office" disabled>
                    <option value=""><%= user.office?.name %></option>
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <div class="col-6">
                  <label for="username" class="form-label">Username</label>
                  <input type="text" class="form-control" id="username" placeholder="Enter Username" name="username" value="<%= user.username %>" />
                </div>
                <div class="col-6">
                  <label for="name" class="form-label">Full Name</label>
                  <input type="text" class="form-control" id="name" placeholder="Enter User's Full Name" name="fullName" value="<%= user.fullName %>" />
                </div>
              </div>
              <div class="row mb-3">
                <div class="col-6">
                  <p class="form-label">User Status</p>
                  <input type="radio" class="btn-check" name="isActive" id="active" autocomplete="off" value="true" <%= user.isActive ? "checked" : "" %>/>
                  <label class="btn btn-outline-success" for="active">Active</label>
                  <input type="radio" class="btn-check" name="isActive" id="inactive" autocomplete="off" value="false" <%= user.isActive ? "" : "checked" %>/>
                  <label class="btn btn-outline-danger" for="inactive">InActive</label>
                </div>
                <div class="col-6">
                  <label for="email" class="form-label">Email ID</label>
                  <input type="email" name="email" id="email" class="form-control" placeholder="Enter Email ID" value="<%= user.email %>" />
                </div>
              </div>
              <button type="submit" class="btn btn-primary w-100">Submit</button>
            </form>
          </div>
        </div>
        <div class="card col-3 mb-5 shadow">
          <div class="card-body">
            <h5>Reset Password</h5>
            <form action="/admin/user/reset_password/<%= user._id %>" id="passwordForm" method="post">
              <label for="password" class="form-label">New Password</label>
              <input type="password" class="form-control mb-2" id="password" placeholder="Enter Password" />

              <label for="confpassword" class="form-label">Confirm Password</label>
              <input type="password" class="form-control mb-3" id="confpassword" placeholder="Confirm Password" name="password"/>

              <div class="mb-3 form-check form-switch">
                <input type="checkbox" class="form-check-input" role="switch" id="showPassword" />
                <label class="form-check-label" for="showPassword">Show Passwords</label>
              </div>

              <button type="submit" class="btn btn-danger w-100">Submit</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <script>
      document.getElementById("showPassword").addEventListener("change", function () {
        const passwordField = document.getElementById("password");
        const confPasswordField = document.getElementById("confpassword");
        const type = this.checked ? "text" : "password";
        passwordField.type = type;
        confPasswordField.type = type;
      });

      document.getElementById("passwordForm").addEventListener("submit", function (event) {
        const password = document.getElementById("password").value;
        const confPassword = document.getElementById("confpassword").value;

        if (password !== confPassword) {
          event.preventDefault();
          alert("Passwords do not match");
        }
      });
    </script>
  </body>
</html>
