<!doctype html>
<html lang="en">
  <%- include('../partials/head', { title: 'Add a New Office'}); %>
  <body>
    <script>
      var error = "<%= error %>";
      if (error) {
        alert(error);
      }
    </script>
    <div class="container">
      <div class="py-3">
        <a href="/admin/offices" class="btn btn-primary">&lt; All Offices</a>
      </div>
      <h3 class="my-4">Add a New Office</h3>
      <div class="card w-75 shadow mb-5">
        <div class="card-body">
          <form action="/admin/office/add" method="post">
            <div class="row mb-3">
              <div class="col-6">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" placeholder="Enter your name" name="name" />
              </div>
              <div class="col-6">
                <label for="id" class="form-label">Office ID (if any)</label>
                <input type="text" class="form-control" id="id" placeholder="Enter Office ID" />
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label for="mobile" class="form-label">Mobile No.</label>
                <input type="tel" name="mobile" id="mobile" class="form-control" placeholder="Enter Primary Mobile Number" />
              </div>
              <div class="col-6">
                <label for="email" class="form-label">Email ID</label>
                <input type="email" name="email" id="email" class="form-control" placeholder="Enter Email ID" />
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label for="whatsapp" class="form-label">Whatsapp No.</label>
                <input type="tel" name="whatsapp" id="whatsapp" class="form-control" placeholder="Enter Whatsapp Number" />
              </div>
              <div class="col-6">
                <label for="landline" class="form-label">Landline</label>
                <input type="text" name="landline" id="landline" class="form-control" placeholder="Enter Landline" />
              </div>
            </div>
            <div class="row mb-3">
              <div class="col">
                <label for="address" class="form-label">Office Address</label>
                <textarea name="address" id="address" class="form-control"></textarea>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label for="block" class="form-label">Block</label>
                <input type="text" name="block" id="block" class="form-control" placeholder="Enter Block" />
              </div>
              <div class="col-6">
                <label for="district" class="form-label">District</label>
                <input type="text" name="district" id="district" class="form-control" placeholder="Enter District" />
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-6">
                <label for="start" class="form-label">Start Date</label>
                <input type="date" name="start_date" id="start" class="form-control" placeholder="Enter Start Date" required />
              </div>
              <div class="col-6">
                <label for="fin" class="form-label">Financial Year</label>
                <input type="text" name="fin_year" id="fin" class="form-control" placeholder="Enter Financial Year. e.g. 2023-2024" />
              </div>
            </div>
            <div class="mb-3">
              <p class="form-label">Enabled Services</p>
              <input type="checkbox" class="btn-check" id="about" name="enabled_services" value="about" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="about">About Us</label>
              <input type="checkbox" class="btn-check" id="ads" name="enabled_services" value="ads" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="ads">Ads</label>
              <input type="checkbox" class="btn-check" id="notice" name="enabled_services" value="notice" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="notice">Notice</label>
              <input type="checkbox" class="btn-check" id="service" name="enabled_services" value="service" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="service">Service</label>
              <input type="checkbox" class="btn-check" id="gallery" name="enabled_services" value="gallery" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="gallery">Gallery</label>
              <input type="checkbox" class="btn-check" id="staff" name="enabled_services" value="staff" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="staff">Staff</label>
              <input type="checkbox" class="btn-check" id="faq" name="enabled_services" value="faq" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="faq">Faq</label>
              <input type="checkbox" class="btn-check" id="grievance" name="enabled_services" value="grievance" autocomplete="off" checked />
              <label class="btn btn-outline-dark" for="grievance">Grievance</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Register</button>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>
